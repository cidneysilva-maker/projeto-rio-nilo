from flask import Flask, request, jsonify, render_template
import sqlite3
from datetime import datetime

app = Flask(__name__)

# DATABASE

def init_db():

    conn = sqlite3.connect("database.db")
    cursor = conn.cursor()

    cursor.execute("""
    CREATE TABLE IF NOT EXISTS readings (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        timestamp TEXT,
        soil INTEGER,
        level TEXT,
        rain INTEGER,
        battery INTEGER,
        pump INTEGER,
        light INTEGER,
        servo TEXT
    )
    """)

    conn.commit()
    conn.close()

init_db()

# CONFIGURAÇÕES

# True  -> Front-end usa simulação
# False -> Front-end usa dados reais do ESP32
DEMO_MODE = True

current_command = "AUTO"

# HOME

@app.route("/")
def home():
    return render_template("index.html")

# RECEBER DADOS DO ESP32

@app.route("/api/dados")
def receber_dados():

    if DEMO_MODE:
        return "DEMO MODE"

    soil = request.args.get("umidade")
    level = request.args.get("nivel")
    rain = request.args.get("chuva")
    battery = request.args.get("bateria")
    pump = request.args.get("bomba")
    light = request.args.get("luminosidade")
    servo = request.args.get("servo")

    conn = sqlite3.connect("database.db")
    cursor = conn.cursor()

    cursor.execute("""
    INSERT INTO readings (
        timestamp,
        soil,
        level,
        rain,
        battery,
        pump,
        light,
        servo
    )
    VALUES (?, ?, ?, ?, ?, ?, ?, ?)
    """, (

        datetime.now().strftime("%H:%M:%S"),

        soil,

        level,

        rain,

        battery,

        pump,

        light,

        servo

    ))

    conn.commit()
    conn.close()

    return "OK"

# STATUS

@app.route("/api/status")
def status():

    if DEMO_MODE:

        return jsonify({

            "demo": True,

            "command": current_command

        })

    conn = sqlite3.connect("database.db")
    cursor = conn.cursor()

    cursor.execute("""

    SELECT *

    FROM readings

    ORDER BY id DESC

    LIMIT 1

    """)

    row = cursor.fetchone()

    conn.close()

    if row:

        return jsonify({

            "demo": False,

            "timestamp": row[1],

            "soil": row[2],

            "level": row[3],

            "rain": row[4],

            "battery": row[5],

            "pump": row[6],

            "light": row[7],

            "servo": row[8],

            "command": current_command

        })

    return jsonify({

        "demo": False

    })

# HISTÓRICO

@app.route("/api/historico")
def historico():

    if DEMO_MODE:
        return jsonify([])

    conn = sqlite3.connect("database.db")
    cursor = conn.cursor()

    cursor.execute("""

    SELECT timestamp, soil

    FROM readings

    ORDER BY id DESC

    LIMIT 20

    """)

    rows = cursor.fetchall()

    conn.close()

    rows.reverse()

    return jsonify(rows)

# COMANDOS

@app.route("/api/comando")
def comando():

    global current_command

    mode = request.args.get("mode")

    if mode:
        current_command = mode

    return jsonify({

        "status": "OK",

        "mode": current_command

    })

# INFORMAÇÕES DO SISTEMA

@app.route("/api/system")
def system():

    return jsonify({

        "demo": DEMO_MODE,

        "version": "2.0",

        "platform": "Smart Irrigation AI",

        "backend": "Flask",

        "database": "SQLite",

        "device": "ESP32"

    })

# START

if __name__ == "__main__":

    app.run(

        host="0.0.0.0",

        port=5000,

        debug=True

    )
